# ============================================================
# 🇪🇬 Egyptian Tourism AI Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# ⚠️ NEVER commit .env to version control!

# --- LLM Provider ---
# Options: "groq" or "gemini"
LLM_PROVIDER=groq

# --- API Keys ---
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

# --- Model Configuration ---
GROQ_MODEL=openai/gpt-oss-120b
GROQ_FAST_MODEL=openai/gpt-oss-20b
GEMINI_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001

# --- Server Configuration ---
HOST=0.0.0.0
PORT=8000
DEBUG=false

# --- AWS Configuration ---
AWS_REGION=us-east-1
AURORA_HOST=your-aurora-cluster.cluster-xxxxx.us-east-1.rds.amazonaws.com
AURORA_USER=your_db_user
AURORA_PASS=your_db_password
AURORA_DB=egyptian_tourism
AURORA_PORT=5432

# --- DynamoDB Tables ---
SESSIONS_TABLE=tourism-sessions
PREFERENCES_TABLE=tourism-preferences
WS_CONNECTIONS_TABLE=tourism-ws-connections

# --- Logging ---
LOG_LEVEL=INFO
